  "components": {
    "schemas": {
      "ConfirmPaymentRequest": {
        "type": "object",
        "properties": {
          "orderId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "transitionId": {
            "type": "string"
          }
        }
      },
      "OrderItemRequest": {
        "type": "object",
        "properties": {
          "menuId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "optionItemSelectedIds": {
            "type": "array",
            "items": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        }
      },
      "OrderRequest": {
        "type": "object",
        "properties": {
          "tableNo": {
            "type": "string"
          },
          "note": {
            "type": [
              "null",
              "string"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemRequest"
            }
          }
        }
      },
      "RequestCategory": {
        "type": "object",
        "properties": {
          "categoryName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "categoryImage": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RequestMenu": {
        "type": "object",
        "properties": {
          "menuName": {
            "type": "string"
          },
          "menuImage": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_available": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "price": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "categoryId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "RequestMenuOptionGroupDto": {
        "type": "object",
